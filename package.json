{
  "name": "hanview-react-app",
  "private": true,
  "version": "2.0.0",
  "license": "SEE LICENSE IN LICENSE",
  "author": "ISM Team <license@ism-team.com>",
  "type": "module",
  "main": "./dist/hanview-react.umd.js",
  "module": "./dist/hanview-react.es.js",
  "types": "./dist/hanview-react.es.d.ts",
  "exports": {
    ".": {
      "types": "./dist/hanview-react.es.d.ts",
      "import": "./dist/hanview-react.es.js",
      "require": "./dist/hanview-react.umd.js"
    },
    "./dist/hanview-react.css": "./dist/hanview-react.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "build:lib:watch": "vite build --config vite.config.lib.ts --watch",
    "package": "npm run build:lib && node scripts/prepare-package.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jszip": "^3.4.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.2.0",
    "terser": "^5.44.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.15"
  }
}