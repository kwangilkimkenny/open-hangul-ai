{
  "name": "open-hangul-ai",
  "private": false,
  "version": "5.0.5",
  "license": "MIT",
  "author": "YATAV Team <ray.kim@yatavent.com>",
  "contributors": [
    {
      "name": "Kwang-il Kim (김광일)",
      "email": "ray.kim@yatavent.com",
      "alternativeEmail": "cac.kikim@gmail.com",
      "url": "https://www.linkedin.com/in/kwang-il-kim-a399b3196/",
      "role": "Lead Developer & Architect"
    }
  ],
  "maintainers": [
    {
      "name": "Kwang-il Kim",
      "email": "cac.kikim@gmail.com",
      "url": "https://www.linkedin.com/in/kwang-il-kim-a399b3196/"
    }
  ],
  "homepage": "https://yatavent.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/kwangilkimkenny/open-hangul-ai"
  },
  "keywords": [
    "open-hangul-ai",
    "document-viewer",
    "hwpx",
    "pdf",
    "docx",
    "ai",
    "llm",
    "editor",
    "korean-docs",
    "hangul",
    "yatav"
  ],
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/open-hangul-ai.umd.js",
  "module": "./dist/open-hangul-ai.es.js",
  "types": "./dist/open-hangul-ai.es.d.ts",
  "exports": {
    ".": {
      "types": "./dist/open-hangul-ai.es.d.ts",
      "import": "./dist/open-hangul-ai.es.js",
      "require": "./dist/open-hangul-ai.umd.js"
    },
    "./dist/open-hangul-ai.css": "./dist/open-hangul-ai.css"
  },
  "scripts": {
    "dev": "vite",
    "proxy": "node server/proxy.js",
    "vertex": "node server/vertex-proxy.js",
    "dev:full": "node server/proxy.js & vite",
    "dev:vertex": "node server/vertex-proxy.js & vite",
    "dev:all": "node server/proxy.js & node server/vertex-proxy.js & vite",
    "build": "tsc -b && vite build",
    "build:community": "vite build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "build:lib:watch": "vite build --config vite.config.lib.ts --watch",
    "build:opensource": "node scripts/build-protected.js opensource",
    "build:production": "node scripts/build-protected.js production",
    "build:enterprise": "node scripts/build-protected.js production && npm run package",
    "package": "npm run build:lib && node scripts/prepare-package.js",
    "package:opensource": "npm run build:opensource && npm run build:lib && node scripts/prepare-package.js opensource",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:report": "playwright show-report",
    "prepare": "husky",
    "security:check": "node scripts/security-check.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.103.0",
    "@tosspayments/payment-sdk": "^1.9.2",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "katex": "^0.16.45",
    "lucide-react": "^0.555.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.14.0",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jszip": "^3.4.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.17",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "express": "^5.2.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^27.2.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.0",
    "terser": "^5.44.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.15"
  }
}
