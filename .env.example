# =============================================================================
# HAN-View React App v4 - Environment Variables Template
# =============================================================================
#
# 듀얼 모드 운영:
# - VITE_SUPABASE_URL이 비어있으면 → 데모 모드 (localStorage)
# - 설정되어 있으면 → 실서버 모드 (Supabase Auth + DB + Storage)
#
# 자세한 배포 가이드: SUPABASE_SETUP.md
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration
# -----------------------------------------------------------------------------
# 비워두면 데모 모드 (메모리 사용자 + 시뮬레이션 결제)
# 설정하면 실서버 모드 (실제 인증 + DB + 결제 서버 검증)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# Toss Payments
# -----------------------------------------------------------------------------
# 테스트 키는 코드에 내장되어 있으므로 운영 키가 있을 때만 설정
# 발급: https://www.tosspayments.com (가맹 신청 후)
VITE_TOSS_CLIENT_KEY=

# =============================================================================
# 기존 환경변수 (아래는 v3 호환)
# =============================================================================
#
# 이 파일을 복사하여 사용하세요:
#   - 개발 환경: .env.development
#   - 프로덕션 환경: .env.production
#   - 로컬 오버라이드: .env.local (gitignore에 포함됨)
#
# 중요: 실제 API 키나 민감한 정보를 이 파일에 작성하지 마세요!
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI API Configuration
# -----------------------------------------------------------------------------
# OpenAI API 키 (선택사항 - 설정하지 않으면 사용자가 UI에서 입력)
# 발급: https://platform.openai.com/api-keys
#
# ⚠️ 보안 경고:
# - 개발/테스트 목적으로만 사용하세요
# - 프로덕션에서는 서버 프록시를 통해 API 호출을 권장합니다
# - 이 키를 절대 공개 저장소에 커밋하지 마세요
VITE_OPENAI_API_KEY=

# API 프록시 서버 URL (설정하면 API 키를 서버에서 관리, 프론트엔드 노출 없음)
# 사용법: node server/proxy.js 실행 후 아래 URL 설정
# VITE_API_PROXY_URL=http://localhost:3001/api/ai/chat

# OpenAI API 엔드포인트 (프록시 미사용 시 직접 호출, 기본값: https://api.openai.com/v1/chat/completions)
VITE_OPENAI_API_ENDPOINT=https://api.openai.com/v1/chat/completions

# OpenAI 모델 (기본값: gpt-4o)
# 옵션: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-4, gpt-3.5-turbo
VITE_OPENAI_MODEL=gpt-4o

# OpenAI Temperature (0.0 ~ 2.0, 기본값: 0.7)
# 낮을수록 일관적, 높을수록 창의적
VITE_OPENAI_TEMPERATURE=0.7

# OpenAI Max Tokens (기본값: 4000)
VITE_OPENAI_MAX_TOKENS=4000

# API 타임아웃 (밀리초, 기본값: 120000 = 2분)
VITE_OPENAI_TIMEOUT=120000

# -----------------------------------------------------------------------------
# Custom API Configuration (업체별 자체 AI API)
# -----------------------------------------------------------------------------
# 커스텀 API 활성화 여부 (true/false)
VITE_CUSTOM_API_ENABLED=false

# 커스텀 API 엔드포인트
VITE_CUSTOM_API_ENDPOINT=

# 커스텀 API 키
VITE_CUSTOM_API_KEY=

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
# 애플리케이션 이름
VITE_APP_NAME=HAN-View React App

# 애플리케이션 버전 (package.json에서 자동 가져오기)
VITE_APP_VERSION=3.0.0

# 개발 서버 포트 (기본값: 5090)
VITE_PORT=5090

# 베이스 URL (기본값: /)
VITE_BASE_URL=/

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
# 최대 파일 크기 (MB, 기본값: 50)
VITE_MAX_FILE_SIZE_MB=50

# 허용되는 파일 확장자 (쉼표로 구분)
VITE_ALLOWED_FILE_EXTENSIONS=.hwpx

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# 로그 레벨 (debug, info, warn, error, 기본값: info)
# 개발: debug, 프로덕션: warn
VITE_LOG_LEVEL=info

# 콘솔 로그 활성화 (true/false, 기본값: 개발 환경에서만 true)
VITE_ENABLE_CONSOLE_LOG=true

# 성능 측정 활성화 (true/false)
VITE_ENABLE_PERFORMANCE_MEASUREMENT=true

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# AI 기능 활성화 (true/false, 기본값: true)
VITE_ENABLE_AI_FEATURES=true

# 테이블 편집 기능 활성화 (true/false, 기본값: true)
VITE_ENABLE_TABLE_EDIT=true

# 이미지 편집 기능 활성화 (true/false, 기본값: true)
VITE_ENABLE_IMAGE_EDIT=true

# 도형 편집 기능 활성화 (true/false, 기본값: true)
VITE_ENABLE_SHAPE_EDIT=true

# PDF 내보내기 기능 활성화 (true/false, 기본값: true)
VITE_ENABLE_PDF_EXPORT=true

# HWPX 내보내기 기능 활성화 (true/false, 기본값: true)
VITE_ENABLE_HWPX_EXPORT=true

# 자동 저장 기능 활성화 (true/false, 기본값: true)
VITE_ENABLE_AUTO_SAVE=true

# 자동 저장 간격 (밀리초, 기본값: 30000 = 30초)
VITE_AUTO_SAVE_INTERVAL=30000

# -----------------------------------------------------------------------------
# UI Configuration
# -----------------------------------------------------------------------------
# 채팅 패널 기본 상태 (open/closed, 기본값: closed)
VITE_CHAT_PANEL_DEFAULT_STATE=closed

# 다크 모드 지원 (true/false, 기본값: false)
VITE_ENABLE_DARK_MODE=false

# 언어 (ko, en, 기본값: ko)
VITE_DEFAULT_LANGUAGE=ko

# -----------------------------------------------------------------------------
# Performance Configuration
# -----------------------------------------------------------------------------
# 번들 크기 경고 임계값 (KB, 기본값: 500)
VITE_CHUNK_SIZE_WARNING_LIMIT=500

# 이미지 최적화 품질 (0-100, 기본값: 80)
VITE_IMAGE_OPTIMIZATION_QUALITY=80

# 캐시 만료 시간 (밀리초, 기본값: 300000 = 5분)
VITE_CACHE_EXPIRATION=300000

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# Content Security Policy 활성화 (true/false, 기본값: true)
VITE_ENABLE_CSP=true

# HTTPS 강제 (true/false, 프로덕션: true)
VITE_FORCE_HTTPS=false

# API 키 암호화 활성화 (true/false, 기본값: true)
VITE_ENABLE_API_KEY_ENCRYPTION=true

# -----------------------------------------------------------------------------
# Cost Management (OpenAI API)
# -----------------------------------------------------------------------------
# 비용 추적 활성화 (true/false, 기본값: true)
VITE_ENABLE_COST_TRACKING=true

# 비용 경고 임계값 (USD, 기본값: 1.0)
VITE_COST_WARNING_THRESHOLD=1.0

# 최대 허용 비용 (USD, 기본값: 10.0)
VITE_COST_MAX_LIMIT=10.0

# Input Token 비용 (USD per 1K tokens, 기본값: 0.00001)
VITE_COST_PER_INPUT_TOKEN=0.00001

# Output Token 비용 (USD per 1K tokens, 기본값: 0.00003)
VITE_COST_PER_OUTPUT_TOKEN=0.00003

# -----------------------------------------------------------------------------
# Debug & Development
# -----------------------------------------------------------------------------
# 디버그 모드 활성화 (true/false, 기본값: false)
VITE_DEBUG_MODE=false

# API 요청 로깅 (true/false, 기본값: false)
VITE_LOG_API_REQUESTS=false

# API 응답 로깅 (true/false, 기본값: false)
VITE_LOG_API_RESPONSES=false

# 소스맵 활성화 (true/false, 개발: true, 프로덕션: false)
VITE_ENABLE_SOURCEMAP=false

# React DevTools 활성화 (true/false, 개발: true, 프로덕션: false)
VITE_ENABLE_REACT_DEVTOOLS=true

# -----------------------------------------------------------------------------
# Analytics & Monitoring (선택사항)
# -----------------------------------------------------------------------------
# Google Analytics ID (선택사항)
VITE_GA_TRACKING_ID=

# Sentry DSN (에러 추적, 선택사항)
VITE_SENTRY_DSN=

# -----------------------------------------------------------------------------
# External Services (선택사항)
# -----------------------------------------------------------------------------
# CDN URL (정적 파일 호스팅, 선택사항)
VITE_CDN_URL=

# WebSocket 서버 URL (실시간 기능, 선택사항)
VITE_WS_URL=

# -----------------------------------------------------------------------------
# Build Configuration
# -----------------------------------------------------------------------------
# 빌드 타겟 (es2015, es2020, esnext, 기본값: es2020)
VITE_BUILD_TARGET=es2020

# 레거시 브라우저 지원 (true/false, 기본값: false)
VITE_LEGACY_SUPPORT=false

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
#
# 환경 변수 사용 방법:
#   1. TypeScript/JavaScript: import.meta.env.VITE_변수명
#   2. 예시: const apiKey = import.meta.env.VITE_OPENAI_API_KEY
#
# Vite 환경 변수 규칙:
#   - VITE_ 접두사가 있는 변수만 클라이언트에 노출됩니다
#   - .env.local은 모든 환경에서 로드되며 git에 커밋되지 않습니다
#   - .env.[mode]는 특정 모드에서만 로드됩니다 (development, production 등)
#
# 우선순위 (높음 → 낮음):
#   1. .env.[mode].local
#   2. .env.[mode]
#   3. .env.local
#   4. .env
#
# 보안 주의사항:
#   - 민감한 정보(API 키, 비밀번호 등)는 .env.local에 저장하세요
#   - .env.local은 gitignore에 포함되어 있어 커밋되지 않습니다
#   - 프로덕션 환경에서는 서버 환경 변수를 사용하세요
#   - API 키는 가능한 서버 프록시를 통해 사용하세요
#
# =============================================================================
