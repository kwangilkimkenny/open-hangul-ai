# =============================================================================
# Development Environment Configuration
# =============================================================================
#
# 이 파일은 개발 환경(npm run dev) 전용 설정입니다.
# 로컬 오버라이드가 필요하면 .env.local 파일을 생성하세요 (gitignore됨)
#
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI API Configuration (개발 환경)
# -----------------------------------------------------------------------------
# ⚠️ 개발용 API 키는 .env.local에 저장하는 것을 권장합니다
# VITE_OPENAI_API_KEY=sk-...

VITE_OPENAI_API_ENDPOINT=https://api.openai.com/v1/chat/completions
VITE_OPENAI_MODEL=gpt-4-turbo-preview
VITE_OPENAI_TEMPERATURE=0.7
VITE_OPENAI_MAX_TOKENS=4000
VITE_OPENAI_TIMEOUT=120000

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
VITE_APP_NAME=HAN-View React App (Dev)
VITE_PORT=5090
VITE_BASE_URL=/

# -----------------------------------------------------------------------------
# File Upload Configuration
# -----------------------------------------------------------------------------
VITE_MAX_FILE_SIZE_MB=50
VITE_ALLOWED_FILE_EXTENSIONS=.hwpx

# -----------------------------------------------------------------------------
# Logging Configuration (개발 환경 - 상세 로깅)
# -----------------------------------------------------------------------------
VITE_LOG_LEVEL=debug
VITE_ENABLE_CONSOLE_LOG=true
VITE_ENABLE_PERFORMANCE_MEASUREMENT=true

# -----------------------------------------------------------------------------
# Feature Flags (개발 환경 - 모든 기능 활성화)
# -----------------------------------------------------------------------------
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_TABLE_EDIT=true
VITE_ENABLE_IMAGE_EDIT=true
VITE_ENABLE_SHAPE_EDIT=true
VITE_ENABLE_PDF_EXPORT=true
VITE_ENABLE_HWPX_EXPORT=true
VITE_ENABLE_AUTO_SAVE=true
VITE_AUTO_SAVE_INTERVAL=30000

# -----------------------------------------------------------------------------
# UI Configuration
# -----------------------------------------------------------------------------
VITE_CHAT_PANEL_DEFAULT_STATE=closed
VITE_ENABLE_DARK_MODE=false
VITE_DEFAULT_LANGUAGE=ko

# -----------------------------------------------------------------------------
# Performance Configuration
# -----------------------------------------------------------------------------
VITE_CHUNK_SIZE_WARNING_LIMIT=500
VITE_IMAGE_OPTIMIZATION_QUALITY=80
VITE_CACHE_EXPIRATION=300000

# -----------------------------------------------------------------------------
# Security Configuration (개발 환경 - 느슨한 보안)
# -----------------------------------------------------------------------------
VITE_ENABLE_CSP=false
VITE_FORCE_HTTPS=false
VITE_ENABLE_API_KEY_ENCRYPTION=true

# -----------------------------------------------------------------------------
# Cost Management
# -----------------------------------------------------------------------------
VITE_ENABLE_COST_TRACKING=true
VITE_COST_WARNING_THRESHOLD=1.0
VITE_COST_MAX_LIMIT=10.0
VITE_COST_PER_INPUT_TOKEN=0.00001
VITE_COST_PER_OUTPUT_TOKEN=0.00003

# -----------------------------------------------------------------------------
# Debug & Development (개발 환경 - 모든 디버그 기능 활성화)
# -----------------------------------------------------------------------------
VITE_DEBUG_MODE=true
VITE_LOG_API_REQUESTS=true
VITE_LOG_API_RESPONSES=true
VITE_ENABLE_SOURCEMAP=true
VITE_ENABLE_REACT_DEVTOOLS=true

# -----------------------------------------------------------------------------
# Build Configuration
# -----------------------------------------------------------------------------
VITE_BUILD_TARGET=es2020
VITE_LEGACY_SUPPORT=false
