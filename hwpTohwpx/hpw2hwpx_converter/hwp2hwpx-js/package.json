{
  "name": "hwp2hwpx-js",
  "version": "1.1.0",
  "description": "HWP to HWPX converter - JavaScript/TypeScript port",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hwp2hwpx": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:wasm": "cd wasm && wasm-pack build --target web --out-dir ../src/wasm/pkg",
    "build:all": "npm run build:wasm && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --coverage --ci --reporters=default --reporters=jest-junit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "hwp",
    "hwpx",
    "hangul",
    "converter",
    "korean",
    "document"
  ],
  "author": "Ported from kr.dogfoot.hwp2hwpx",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kwangilkimkenny/hpw2hwpx_converter.git",
    "directory": "hwp2hwpx-js"
  },
  "bugs": {
    "url": "https://github.com/kwangilkimkenny/hpw2hwpx_converter/issues"
  },
  "homepage": "https://github.com/kwangilkimkenny/hpw2hwpx_converter/tree/main/hwp2hwpx-js#readme",
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.19.27",
    "@types/pako": "^2.0.4",
    "@typescript-eslint/eslint-plugin": "^6.18.1",
    "@typescript-eslint/parser": "^6.18.1",
    "adm-zip": "^0.5.16",
    "cfb": "^1.2.2",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "pako": "^2.1.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "typedoc": "^0.27.6",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "commander": "^14.0.2",
    "hwplib-js": "file:../hwplib-js",
    "iconv-lite": "^0.6.3",
    "jszip": "^3.10.1",
    "xml2js": "^0.6.2"
  },
  "files": [
    "dist",
    "src/wasm/pkg"
  ],
  "engines": {
    "node": ">=14.0.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "test/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
